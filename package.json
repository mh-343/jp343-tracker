{
  "name": "jp343-extension",
  "version": "2.2.0",
  "description": "Track your Japanese immersion time on streaming platforms",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "release": "node scripts/build-release.cjs",
    "postinstall": "wxt prepare"
  },
  "keywords": [
    "browser-extension",
    "japanese",
    "immersion",
    "time-tracking"
  ],
  "author": "JP343",
  "license": "GPL-3.0-only",
  "devDependencies": {
    "archiver": "^7.0.1",
    "typescript": "^5.9.3",
    "wxt": "^0.20.13"
  }
}
