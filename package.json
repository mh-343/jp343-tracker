{
  "name": "jp343-extension",
  "version": "2.8.6",
  "description": "Auto-track your Japanese immersion time on streaming platforms",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "release": "node scripts/build-release.cjs",
    "typecheck": "wxt prepare && tsc --noEmit",
    "lint": "eslint src/",
    "check": "npm run lint",
    "prebuild": "npm run check",
    "prebuild:firefox": "npm run check",
    "prezip": "npm run check",
    "prezip:firefox": "npm run check",
    "postinstall": "wxt prepare"
  },
  "keywords": [
    "browser-extension",
    "japanese",
    "immersion",
    "time-tracking"
  ],
  "author": "JP343",
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "archiver": "^7.0.1",
    "eslint": "^10.4.0",
    "typescript": "^5.9.3",
    "wxt": "^0.20.13"
  }
}
